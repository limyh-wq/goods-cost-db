# PostgreSQL connection (docker-compose default below)
DATABASE_URL="postgresql://goods:goods@localhost:5432/goods_cost?schema=public"

# Local file storage
STORAGE_DRIVER="local"
# Directory (relative to project root) where uploaded files are stored
LOCAL_STORAGE_DIR="storage"
# Public base path used to serve/download files
STORAGE_PUBLIC_BASE="/api/files"

# Max upload size in bytes (default 25MB)
MAX_UPLOAD_BYTES="26214400"
